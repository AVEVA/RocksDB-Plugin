set(AVEVA_ROCKSDB_PLUGIN_CORE_VERSION @PROJECT_VERSION@)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(boost_algorithm REQUIRED)
find_dependency(boost_container REQUIRED)
find_dependency(boost_crc REQUIRED)
find_dependency(boost_interprocess REQUIRED)
find_dependency(boost_scope REQUIRED)
find_dependency(boost_log REQUIRED)
find_dependency(boost_intrusive REQUIRED)
find_dependency(boost_endian REQUIRED)
find_dependency(boost_thread REQUIRED)
find_dependency(boost_unordered REQUIRED)

include(${CMAKE_CURRENT_LIST_DIR}/aveva-rocksdb-plugin-core-targets.cmake)

check_required_components(aveva-rocksdb-plugin-core)
